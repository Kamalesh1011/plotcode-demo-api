# ==========================================
# Plotcode — Environment Configuration v3
# MongoDB Atlas (Serverless) Edition
# ==========================================

# --- Server ---
AGENT_API_PORT=8001
NODE_ENV=development

# --- MongoDB Atlas (Required) ---
# Get your URI from: https://cloud.mongodb.com → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=mongodb+srv://:@cluster0.ovgip5j.mongodb.net/?appName=Cluster0
MONGODB_DB=plotcode_db

# --- LLM (OpenRouter — Recommended) ---
# Get API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_LLM_MODEL=openai/gpt-4o

# --- GitHub ---
# Create at: https://github.com/settings/tokens/new (scopes: repo, workflow)
GITHUB_TOKEN=
GITHUB_ORG=Kamalesh1011
GITHUB_DEFAULT_REPO=plotcode-demo-api

# --- Telegram Bot ---
# Create bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=8878824628:
TELEGRAM_ADMIN_CHAT_ID=

# --- RBAC: comma-separated Telegram user IDs ---
ADMIN_TELEGRAM_IDS=
PROD_OWNER_TELEGRAM_IDS=

# --- API Security ---
# Change this in production! Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AGENT_API_KEY=plotcode-dev-key-change-in-prod

# --- Auth (JWT + Admin user) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@.local

# --- GitHub OAuth ---
# Create at: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5173/auth/github/callback

# --- Google OAuth ---
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# --- Chatbot ---
CHAT_LLM_MODEL=openai/gpt-4o-mini

# --- CI Workflows ---
CI_WORKFLOW_FILENAME=ci.yml
DEPLOY_WORKFLOW_FILENAME=deploy.yml

# --- Agent Workspace ---
AGENT_WORKSPACE=./workspace/repos

# --- Deployment ---
# Use ngrok (ngrok http 8001) to expose local API to GitHub Actions webhooks
PLOTCODE_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app
STAGING_ENV_URL=https://your-app-staging.onrender.com
PRODUCTION_ENV_URL=https://your-app.onrender.com

# --- Production URLs ---
# Frontend (Vercel):  https://plotcode.vercel.app
# Backend (Railway):  https://plotcode-api.up.railway.app
# Git Server (VPS):   ssh://git@your-vps-ip:2222/repos
PRODUCTION_FRONTEND_URL=https://plotcode.vercel.app
PRODUCTION_BACKEND_URL=https://plotcode-api.up.railway.app
GIT_SSH_HOST=
GIT_SSH_PORT=2222
GIT_HTTP_URL=
CI_TOKEN=changeme-ci-token

# --- CI ---
CI_PLATFORM=github_actions
CI_MAX_RETRY=3
