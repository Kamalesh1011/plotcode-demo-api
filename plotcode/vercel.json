{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/index.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/auth/:path*", "destination": "/api/index.py" },
    { "source": "/ws/:path*", "destination": "/api/index.py" },
    { "source": "/chat", "destination": "/api/index.py" },
    { "source": "/repos/:path*", "destination": "/api/index.py" },
    { "source": "/commits", "destination": "/api/index.py" },
    { "source": "/pulls", "destination": "/api/index.py" },
    { "source": "/issues", "destination": "/api/index.py" },
    { "source": "/contents", "destination": "/api/index.py" },
    { "source": "/file", "destination": "/api/index.py" },
    { "source": "/check-runs", "destination": "/api/index.py" },
    { "source": "/services", "destination": "/api/index.py" },
    { "source": "/metrics", "destination": "/api/index.py" },
    { "source": "/prompts", "destination": "/api/index.py" },
    { "source": "/agents/:path*", "destination": "/api/index.py" },
    { "source": "/trigger", "destination": "/api/index.py" },
    { "source": "/trigger/:path*", "destination": "/api/index.py" },
    { "source": "/requests/:path*", "destination": "/api/index.py" },
    { "source": "/requests", "destination": "/api/index.py" },
    { "source": "/audit/:path*", "destination": "/api/index.py" },
    { "source": "/webhooks", "destination": "/api/index.py" },
    { "source": "/webhooks/:path*", "destination": "/api/index.py" },
    { "source": "/feature-flags", "destination": "/api/index.py" },
    { "source": "/feature-flags/:path*", "destination": "/api/index.py" },
    { "source": "/system/:path*", "destination": "/api/index.py" },
    { "source": "/upload", "destination": "/api/index.py" },
    { "source": "/uploads", "destination": "/api/index.py" },
    { "source": "/uploads/:path*", "destination": "/api/index.py" },
    { "source": "/ci-webhook", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
